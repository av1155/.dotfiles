{
    "$schema": "https://opencode.ai/config.json",

    "model": "openai/gpt-5.5",

    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "http://localhost:11434/v1",
            },
            "models": {
                "qwen3.6-coding-128k": {
                    "name": "Qwen 3.6 Coding 128K",
                },
            },
        },
        "llamacpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp (local)",
            "options": {
                "baseURL": "http://127.0.0.1:1235/v1",
            },
            "models": {
                "qwen3.6-35b-a3b": {
                    "name": "Qwen 3.6 35B A3B",
                    "limit": {
                        "context": 262144,
                        "output": 32768,
                    },
                },
            },
        },
    },

    "lsp": {
        // Match nvim's TS server (LazyVim default). vtsls is on PATH via pnpm.
        "vtsls": {
            "command": ["vtsls", "--stdio"],
            "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"],
        },
        // Disable opencode's tsserver-based default since vtsls replaces it.
        "typescript": { "disabled": true },
        // pyright: leave as built-in. The shell auto-activates .venv (zshrc
        // _venv_auto_activate) and projects pin python/imports via
        // [tool.pyright] in pyproject.toml (venvPath/venv).
    },

    "permission": {
        "edit": "ask",
        "webfetch": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.local": "deny",
            "*.env.*.local": "deny",
            "**/.env": "deny",
            "**/.env.local": "deny",
            "**/.env.*.local": "deny",
            "secrets/**": "deny",
            "**/credentials*": "deny",
            "**/*.pem": "deny",
            "~/.ssh/**": "deny",
            "~/.aws/**": "deny",
            "~/.gnupg/**": "deny",
            "~/.docker/config.json": "deny",
            "~/.npmrc": "deny",
            "~/.config/gh/**": "deny",
        },
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "cat *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "fd *": "allow",
            "find *": "allow",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git branch*": "allow",
            "git show*": "allow",
            "git remote*": "allow",
            "sudo *": "deny",
            "chmod 777 *": "deny",
            "rm -rf /*": "deny",
            "dd *": "deny",
            "mkfs *": "deny",
            "drop table*": "deny",
            "DROP TABLE*": "deny",
            "git push *": "ask",
            "git merge *": "ask",
            "git reset --hard*": "ask",
            "curl *|sh": "ask",
            "wget *|sh": "ask",
            "pnpm install *": "ask",
            "pnpm add *": "ask",
            "pnpm remove *": "ask",
            "pnpm publish *": "ask",
            "npm publish *": "ask",
        },
    },

    "formatter": {
        "prettier": {
            // Let prettier discover config (project rc wins; ~/.prettierrc.json
            // is found via upward search for files under ~). Mirrors prettierd's
            // PRETTIERD_DEFAULT_CONFIG semantics: global as fallback, not override.
            "command": ["prettier", "--write", "$FILE"],
        },
        "clang-format": {
            "command": ["clang-format", "-i", "-style=file", "$FILE"],
        },
        "stylua": {
            "command": ["stylua", "--config-path", "{env:HOME}/.config/nvim/stylua.toml", "$FILE"],
            "extensions": [".lua"],
        },
    },

    "mcp": {
        "magic": {
            "type": "local",
            "enabled": false,
            "environment": { "API_KEY": "{env:MAGIC_API_KEY}" },
            "command": ["npx", "-y", "@21st-dev/magic@latest"],
        },
        "stitch": {
            "type": "remote",
            "enabled": false,
            "url": "https://stitch.googleapis.com/mcp",
            "headers": {
                "X-Goog-Api-Key": "{env:GOOGLE_STITCH_API_KEY}",
            },
        },
        "context-mode": {
            "type": "local",
            "enabled": true,
            "command": ["npx", "-y", "context-mode"],
        },
    },

    "agent": {
        "build": {
            "mode": "primary",
            "permission": {
                "edit": "allow",
                "webfetch": "allow",
                "websearch": "allow",
                "task": "allow",
                "skill": "allow",
                "magic*": "allow",
                "stitch*": "allow",
                "context-mode*": "allow",
                "supabase*": "ask",
                "vercel*": "ask",
            },
        },
        "plan": {
            "mode": "primary",
            "permission": {
                "edit": "deny",
                "webfetch": "allow",
                "websearch": "allow",
                "task": "allow",
                "skill": "allow",
                "magic*": "allow",
                "stitch*": "allow",
                "context-mode*": "allow",
                "supabase*": "ask",
                "vercel*": "ask",
            },
        },
    },
}
