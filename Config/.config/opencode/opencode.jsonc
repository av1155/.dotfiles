{
    "$schema": "https://opencode.ai/config.json",

    "model": "openai/gpt-5.5",

    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama (local)",
            "options": {
                "baseURL": "http://localhost:11434/v1",
            },
            "models": {
                "qwen3.6-coding-128k": {
                    "name": "Qwen 3.6 Coding 128K",
                },
            },
        },
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LM Studio (local)",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1",
            },
            "models": {
                "qwen3.6-35b-a3b": {
                    "name": "Qwen 3.6 35B A3B (local)",
                },
            },
        },
    },

    "permission": {
        "edit": "ask",
        "webfetch": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.local": "deny",
            "*.env.*.local": "deny",
            "**/.env": "deny",
            "**/.env.local": "deny",
            "**/.env.*.local": "deny",
            "secrets/**": "deny",
            "**/credentials*": "deny",
            "**/*.pem": "deny",
            "~/.ssh/**": "deny",
            "~/.aws/**": "deny",
            "~/.gnupg/**": "deny",
            "~/.docker/config.json": "deny",
            "~/.npmrc": "deny",
            "~/.config/gh/**": "deny",
        },
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "cat *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "fd *": "allow",
            "find *": "allow",
            "git status*": "allow",
            "git diff*": "allow",
            "git log*": "allow",
            "git branch*": "allow",
            "git show*": "allow",
            "git remote*": "allow",
            "sudo *": "deny",
            "chmod 777 *": "deny",
            "rm -rf /*": "deny",
            "dd *": "deny",
            "mkfs *": "deny",
            "drop table*": "deny",
            "DROP TABLE*": "deny",
            "git push *": "ask",
            "git merge *": "ask",
            "git reset --hard*": "ask",
            "curl *|sh": "ask",
            "wget *|sh": "ask",
            "pnpm install *": "ask",
            "pnpm add *": "ask",
            "pnpm remove *": "ask",
            "pnpm publish *": "ask",
            "npm publish *": "ask",
        },
    },

    "formatter": {
        "prettier": {
            "command": ["prettier", "--config", "{env:HOME}/.prettierrc.json", "--write", "$FILE"],
        },
        "clang-format": {
            "command": ["clang-format", "-i", "-style=file", "$FILE"],
        },
        "stylua": {
            "command": ["stylua", "--config-path", "{env:HOME}/.config/nvim/stylua.toml", "$FILE"],
            "extensions": [".lua"],
        },
    },

    "mcp": {
        "context7": {
            "type": "remote",
            "enabled": true,
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
            },
        },
        "firecrawl": {
            "type": "local",
            "enabled": true,
            "environment": { "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}" },
            "command": ["npx", "-y", "firecrawl-mcp"],
        },
        "playwright": {
            "type": "local",
            "enabled": true,
            "command": ["npx", "@playwright/mcp@latest", "--output-dir", "."],
        },
        "semgrep": {
            "type": "local",
            "enabled": true,
            "command": ["semgrep", "mcp"],
        },
        "github": {
            "type": "remote",
            "enabled": true,
            "url": "https://api.githubcopilot.com/mcp/",
            "headers": {
                "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
            },
        },
    },

    "agent": {
        "build": {
            "mode": "primary",
            "permission": {
                "edit": "allow",
                "webfetch": "allow",
                "websearch": "allow",
                "task": "allow",
                "skill": "allow",
                "context7*": "allow",
                "firecrawl*": "allow",
                "semgrep*": "allow",
                "playwright*": "ask",
                "github*": "ask",
                "supabase*": "ask",
                "vercel*": "ask",
            },
        },
        "plan": {
            "mode": "primary",
            "permission": {
                "edit": "deny",
                "webfetch": "allow",
                "websearch": "allow",
                "task": "allow",
                "skill": "allow",
                "context7*": "allow",
                "firecrawl*": "allow",
                "semgrep*": "allow",
                "playwright*": "ask",
                "github*": "ask",
                "supabase*": "ask",
                "vercel*": "ask",
            },
        },
    },
}
