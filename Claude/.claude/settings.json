{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "autoDreamEnabled": true,
    "cleanupPeriodDays": 30,
    "effortLevel": "high",
    "env": {
        "CLAUDE_CODE_NO_FLICKER": "1"
    },
    "enabledPlugins": {
        "claude-notifications-go@claude-notifications-go": true,
        "code-review@claude-plugins-official": true,
        "context7@claude-plugins-official": true,
        "firecrawl@claude-plugins-official": true,
        "frontend-design@claude-plugins-official": true,
        "github@claude-plugins-official": true,
        "lua-lsp@claude-plugins-official": true,
        "playwright@claude-plugins-official": true,
        "pyright-lsp@claude-plugins-official": true,
        "security-guidance@claude-plugins-official": true,
        "skill-codex@skill-codex": true,
        "supabase@claude-plugins-official": true,
        "typescript-lsp@claude-plugins-official": true,
        "ui-ux-pro-max@ui-ux-pro-max-skill": true,
        "vercel-plugin@vercel-vercel-plugin": true
    },
    "extraKnownMarketplaces": {
        "claude-notifications-go": {
            "source": {
                "repo": "777genius/claude-notifications-go",
                "source": "github"
            }
        },
        "skill-codex": {
            "source": {
                "repo": "skills-directory/skill-codex",
                "source": "github"
            }
        },
        "ui-ux-pro-max-skill": {
            "source": {
                "repo": "nextlevelbuilder/ui-ux-pro-max-skill",
                "source": "github"
            }
        },
        "vercel-vercel-plugin": {
            "source": {
                "path": "/Users/andreaventi/.cache/plugins/github.com-vercel-vercel-plugin",
                "source": "directory"
            }
        }
    },
    "hooks": {
        "Notification": [
            {
                "hooks": [
                    {
                        "command": "workmux set-window-status waiting",
                        "type": "command"
                    }
                ],
                "matcher": "permission_prompt|elicitation_dialog"
            }
        ],
        "PostToolUse": [
            {
                "hooks": [
                    {
                        "command": "workmux set-window-status working",
                        "type": "command"
                    }
                ]
            }
        ],
        "PreToolUse": [],
        "Stop": [
            {
                "hooks": [
                    {
                        "command": "workmux set-window-status done",
                        "type": "command"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "command": "workmux set-window-status working",
                        "type": "command"
                    }
                ]
            }
        ]
    },
    "outputStyle": "Explanatory",
    "permissions": {
        "allow": [],
        "ask": [
            "Bash(git push *)",
            "Bash(git merge *)",
            "Bash(pnpm install *)",
            "Bash(pnpm add *)",
            "Bash(pnpm remove *)"
        ],
        "defaultMode": "plan",
        "deny": [
            "Read(./.env)",
            "Read(./.env.local)",
            "Read(./.env.*.local)",
            "Read(**/.env.local)",
            "Read(**/.env.*.local)",
            "Read(./secrets/**)",
            "Read(**/credentials*)",
            "Read(**/*.pem)",
            "Read(~/.ssh/**)",
            "Read(~/.aws/**)",
            "Read(~/.gnupg/**)",
            "Read(~/.docker/config.json)",
            "Read(~/.npmrc)",
            "Read(~/.config/gh/**)",
            "Write(./.env)",
            "Write(./.env.*)",
            "Bash(sudo *)",
            "Bash(chmod 777 *)",
            "Bash(git push --force*)",
            "Bash(git push -f*)",
            "Bash(git push origin main*)",
            "Bash(git push origin master*)",
            "Bash(git push origin :*)",
            "Bash(git reset --hard*)",
            "Bash(curl *| sh)",
            "Bash(wget *| sh)",
            "Bash(pnpm publish *)",
            "Bash(npm publish *)",
            "Bash(drop table*)",
            "Bash(DROP TABLE*)",
            "Bash(dd *)",
            "Bash(mkfs *)"
        ]
    },
    "respectGitignore": false,
    "statusLine": {
        "command": "~/.claude/statusline.sh",
        "type": "command"
    }
}
