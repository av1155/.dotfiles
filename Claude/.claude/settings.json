{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "cleanupPeriodDays": 30,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(./secrets/**)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.config/gh/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push origin :*)",
      "Bash(git reset --hard*)",
      "Bash(curl *| sh)",
      "Bash(wget *| sh)",
      "Bash(pnpm publish *)",
      "Bash(npm publish *)",
      "Bash(drop table*)",
      "Bash(DROP TABLE*)",
      "Bash(dd *)",
      "Bash(mkfs *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(pnpm install *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE 'rm\\s+-(rf|fr)\\s+/(\\s|\\*|$|;)|rm\\s+-(rf|fr)\\s+\\*|rm\\s+-(rf|fr)\\s+\\.|rm\\s+-(rf|fr)\\s+~'; then echo '❌ BLOCKED: rm -rf with dangerous target.' >&2; exit 2; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE 'git\\s+push\\s+(--force|-f)|git\\s+push\\s+origin\\s+(main|master)'; then echo '❌ BLOCKED: Direct push to main/master or force push. Create a feature branch and PR instead.' >&2; exit 2; fi; exit 0"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-codex@skill-codex": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "vercel-plugin@vercel-vercel-plugin": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "skill-codex": {
      "source": {
        "source": "github",
        "repo": "skills-directory/skill-codex"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/andreaventi/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "outputStyle": "Explanatory",
  "effortLevel": "high",
  "autoDreamEnabled": true
}
