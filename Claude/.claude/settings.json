{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "cleanupPeriodDays": 30,
    "respectGitignore": false,
    "outputStyle": "Explanatory",
    "effortLevel": "medium",
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "permissions": {
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Read(./config/credentials.json)"
        ]
    }
}
